# ==================================================
# Teacher Shelter - Backend Docker Compose 환경 변수
# 이 파일을 .env로 복사하여 사용하세요
# ==================================================

# ============================================
# 도메인 설정
# ============================================
DOMAIN=api.teacherlounge.co.kr

# GitHub Repository (docker-compose에서 이미지 pull용)
GITHUB_REPOSITORY=your-username/teacher-shelter

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=teacher_shelter
POSTGRES_PASSWORD=<GENERATE: openssl rand -base64 24>
POSTGRES_DB=teacher_shelter

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=<GENERATE: openssl rand -base64 24>

# ============================================
# JWT 인증
# ============================================
JWT_SECRET=<GENERATE: openssl rand -base64 32>
REFRESH_TOKEN_SECRET=<GENERATE: openssl rand -base64 32>

# ============================================
# 보안
# ============================================
IP_HASH_SALT=<GENERATE: openssl rand -hex 16>
FILE_ENCRYPTION_KEY=<GENERATE: openssl rand -base64 32>

# ============================================
# CORS 허용 도메인 (Vercel 포함)
# ============================================
ALLOWED_ORIGINS=https://teacherlounge.co.kr,https://www.teacherlounge.co.kr,https://teacher-shelter.vercel.app

# ============================================
# Frontend URL (Vercel)
# ============================================
FRONTEND_URL=https://teacherlounge.co.kr

# ============================================
# 쿠키 설정 (크로스 도메인 인증 필수!)
# ============================================
# 프론트엔드(teacherlounge.co.kr)와 백엔드(api.teacherlounge.co.kr) 간
# 쿠키 공유를 위해 반드시 설정 필요
# 앞에 점(.)을 붙여야 서브도메인 간 공유 가능
COOKIE_DOMAIN=.teacherlounge.co.kr

# ============================================
# OAuth 리다이렉트 허용 Origin (Open Redirect 방지)
# ============================================
ALLOWED_REDIRECT_ORIGINS=https://teacherlounge.co.kr,https://www.teacherlounge.co.kr

# ============================================
# 이메일 (SMTP) - 프로덕션 필수!
# Gmail 앱 비밀번호: https://myaccount.google.com/apppasswords
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=noreply@teacherlounge.co.kr

# ============================================
# OAuth2 (선택)
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.teacherlounge.co.kr/api/auth/google/callback

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=https://api.teacherlounge.co.kr/api/auth/kakao/callback

# Naver OAuth
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=https://api.teacherlounge.co.kr/api/auth/naver/callback
